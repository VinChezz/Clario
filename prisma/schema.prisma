generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  files     File[]
  teams     Team[]   @relation("TeamCreator")

  invited   Invite[] @relation("Inviter")
  received  Invite[] @relation("Invitee")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  files       File[]
  invites     Invite[]
  createdBy   User     @relation("TeamCreator", fields: [createdById], references: [id])
}

model File {
  id          String   @id @default(cuid())
  fileName    String
  archive     Boolean
  document    String?
  whiteboard  String?
  teamId      String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isPublic    Boolean  @default(false)
  permissions String   @default("VIEW")
  shareToken  String?  @unique
  version     Int      @default(1)
  createdBy   User     @relation(fields: [createdById], references: [id])
  team        Team     @relation(fields: [teamId], references: [id])
}

model Invite {
  id        String   @id @default(cuid())
  token     String   @unique
  teamId    String
  inviterId String
  inviteeId String?
  email     String?
  type      String
  status    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team    Team @relation(fields: [teamId], references: [id])
  inviter User @relation("Inviter", fields: [inviterId], references: [id])
  invitee User? @relation("Invitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([expiresAt])
}
