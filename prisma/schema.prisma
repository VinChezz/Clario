generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  image       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  files       File[]
  received    Invite[]     @relation("Invitee")
  invited     Invite[]     @relation("Inviter")
  teams       Team[]       @relation("TeamCreator")
  teamMembers TeamMember[]
}

model Team {
  id          String       @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  files       File[]
  invites     Invite[]
  createdBy   User         @relation("TeamCreator", fields: [createdById], references: [id])
  members     TeamMember[]
}

model File {
  id          String   @id @default(cuid())
  fileName    String
  archive     Boolean
  document    String?
  whiteboard  String?
  teamId      String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isPublic    Boolean  @default(false)
  permissions String   @default("VIEW")
  shareToken  String?  @unique
  version     Int      @default(1)
  createdBy   User     @relation(fields: [createdById], references: [id])
  team        Team     @relation(fields: [teamId], references: [id])
}

model Invite {
  id        String   @id @default(cuid())
  token     String   @unique
  teamId    String
  inviterId String
  inviteeId String?
  email     String?
  type      String
  status    String   @default("PENDING")
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role     @default(VIEW)
  invitee   User?    @relation("Invitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviter   User     @relation("Inviter", fields: [inviterId], references: [id])
  team      Team     @relation(fields: [teamId], references: [id])

  @@index([token])
  @@index([email])
  @@index([expiresAt])
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  role     Role     @default(VIEW)
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

enum Role {
  VIEW
  EDIT
}
